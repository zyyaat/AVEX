// Prisma schema for AVEX - Global Delivery App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  passwordHash String
  loyaltyPoints Int @default(0)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  addresses Address[]
  favorites Favorite[]
  cards     SavedCard[]
  orders    Order[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  lat         Float?
  lng         Float?
  locationUrl String?
  addressText String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([userId, menuItemId])
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  description String?
  descriptionAr String?
  image       String?
  imageUrl    String?
  coverUrl    String?
  rating      Float    @default(4.5)
  ratingCount Int      @default(0)
  deliveryTimeMin Int  @default(20)
  deliveryTimeMax Int  @default(45)
  deliveryFee Float    @default(3.99)
  minOrder    Float    @default(0)
  isActive    Boolean  @default(true)
  isPro       Boolean  @default(false)
  cuisines    String?  // comma separated: "عربي, برغر, بيتزا"
  createdAt   DateTime @default(now())
  menuItems   MenuItem[]
  orders      Order[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  icon      String   @default("🍽️")
  imageUrl  String?
  order     Int      @default(0)
  items     MenuItem[]
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  description String
  descriptionAr String
  price       Float
  image       String   @default("🍽️")
  imageUrl    String?
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  rating      Float    @default(4.5)
  ratingCount Int      @default(0)
  prepTime    Int      @default(15)
  calories    Int      @default(0)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  restaurantId String
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  favorites   Favorite[]
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  restaurantId String?
  restaurant  Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  customerName String
  phone       String
  locationLat  Float?
  locationLng  Float?
  locationUrl  String?
  locationAddress String?
  subtotal    Float
  deliveryFee Float
  discount    Float    @default(0)
  tax         Float    @default(0)
  couponCode  String?
  total       Float
  paymentMethod String @default("cash")
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem  MenuItem? @relation(fields: [menuItemId], references: [id])
  name      String
  price     Float
  quantity  Int
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  descriptionAr String?
  type        String   @default("percentage")
  value       Float
  minOrder    Float    @default(0)
  maxDiscount Float?
  isActive    Boolean  @default(true)
  usageLimit  Int?
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SavedCard {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymobToken   String
  brand         String
  last4         String
  expMonth      Int
  expYear       Int
  cardholderName String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}
