# ===== AVEX Environment Variables =====
# Copy to .env and adjust

# Go Backend
PORT=8080
DB_DRIVER=sqlite
DB_PATH=./backend/avex.db
JWT_SECRET=avex-production-secret-change-me

# PostgreSQL (for production)
# DB_DRIVER=postgres
# DATABASE_URL=host=localhost port=5432 user=postgres password=postgres dbname=avex sslmode=disable

# Paymob (optional - configure via admin dashboard)
# PAYMOB_API_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_IFRAME_ID=
# PAYMOB_HMAC_SECRET=
